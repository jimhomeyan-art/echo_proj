.pnp
.pnp.js
.pnpm-store/
.yarn/

# 构建产物
dist/
dist-ssr/
build/
out/
.vite/
.next/
.cache/
.turbo/

# 环境变量（含 API Key，不能提交）
.env
.env.local
.env.*.local
.env.development
.env.production
echoes-app/server/.env
echoes-app/echoes-web/.env
echoes-app/melody-soul-project/melody-soul/.env
*.env

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
echoes-app/server/server.log
echoes-app/server/server-test.log
echoes-app/server/server-test.err
echoes-app/echoes-web/vite.log
echoes-app/echoes-web/vite.err

# 测试 / 临时
smoke-test.cjs
chat-debug.png
debug-chat.cjs
jianghu_readme.txt
*.tmp
*.temp

# 编辑器与系统
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

