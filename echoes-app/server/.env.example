# AI 音乐生成配置
# 复制本文件为 .env 并填入真实 API Key
# 可选: mureka / mock
MUSIC_PROVIDER=mureka

# Mureka API 配置（去 https://platform.mureka.ai 申请）
MUREKA_API_KEY=YOUR_MUREKA_API_KEY
MUREKA_API_BASE_URL=https://api.mureka.ai
MUREKA_GENERATE_PATH=/v1/instrumental/generate
MUREKA_STATUS_PATH=/v1/instrumental/query/:taskId
MUREKA_MODEL=auto
MUREKA_N=1
MUREKA_STREAM=true

# 通用音乐配置
MUSIC_DURATION=60
MUSIC_REQUEST_TIMEOUT=30000
MUSIC_STATUS_TIMEOUT=10000

# 千问 / DashScope 聊天模型配置（去 https://bailian.console.aliyun.com 申请）
QWEN_API_KEY=YOUR_QWEN_API_KEY
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
CHAT_REQUEST_TIMEOUT=60000

# 服务器端口（Render 会注入 PORT，本地默认 3001）
PORT=3001

# 跨域白名单（逗号分隔），生产填上你的 Vercel 域名
# 例：https://echoes.vercel.app,https://echoes-foo.vercel.app
# 留空则全放行（仅本地开发用）
CORS_ORIGINS=
