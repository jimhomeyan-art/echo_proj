/* pages/channel/index.wxss */

.page {
  min-height: 100vh;
  position: relative;
  padding-bottom: 160rpx;
}

.background {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
}

.gradient-layer {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #0D1B2A 0%, #1B263B 50%, #0D1B2A 100%);
}

.status-bar {
  height: env(safe-area-inset-top);
  position: relative;
  z-index: 1;
}

.header {
  position: relative;
  z-index: 1;
  padding: var(--spacing-lg) var(--spacing-xl);
}

.page-title {
  font-size: var(--font-size-h1);
  font-weight: 300;
  color: var(--color-text-primary);
  display: block;
}

.page-subtitle {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  display: block;
  margin-top: var(--spacing-xs);
}

.content {
  position: relative;
  z-index: 1;
  padding: 0 var(--spacing-xl);
}

/* Frequency Card */
.frequency-card {
  padding: var(--spacing-lg);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-xl);
}

.frequency-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.frequency-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.frequency-wave {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 30rpx;
  height: 30rpx;
  border: 2rpx solid var(--color-accent-warm);
  border-radius: 50%;
  animation: radarPing 2s ease-out infinite;
}

@keyframes radarPing {
  0% {
    transform: translate(-50%, -50%) scale(0.5);
    opacity: 1;
  }
  100% {
    transform: translate(-50%, -50%) scale(2);
    opacity: 0;
  }
}

.frequency-label {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
}

.frequency-value {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-lg);
}

.freq-number {
  font-size: 72rpx;
  font-weight: 200;
  color: var(--color-text-primary);
  letter-spacing: -2rpx;
}

.freq-unit {
  font-size: var(--font-size-h3);
  color: var(--color-text-secondary);
}

/* Emotion Selector */
.emotion-selector {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.emotion-pill {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-xs) var(--spacing-md);
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-full);
  transition: all 0.3s ease;
}

.emotion-pill.active {
  background: rgba(224, 122, 95, 0.15);
  border-color: var(--color-accent-warm);
}

.pill-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.emotion-pill text {
  font-size: var(--font-size-micro);
  color: var(--color-text-secondary);
}

.emotion-pill.active text {
  color: var(--color-text-primary);
}

/* Radar Section */
.radar-section {
  margin-bottom: var(--spacing-xl);
}

.section-label {
  font-size: var(--font-size-caption);
  color: var(--color-text-muted);
  display: block;
  margin-bottom: var(--spacing-md);
}

.radar-container {
  position: relative;
  width: 500rpx;
  height: 500rpx;
  margin: 0 auto var(--spacing-lg);
}

.radar-container.active {
  animation: radarFlash 0.5s ease-out;
}

@keyframes radarFlash {
  0%, 100% { filter: brightness(1); }
  50% { filter: brightness(1.3); }
}

/* Radar Circles */
.radar-circles {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  height: 100%;
}

.circle {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.circle.c1 { width: 33%; height: 33%; }
.circle.c2 { width: 66%; height: 66%; }
.circle.c3 { width: 100%; height: 100%; }

/* Radar Sweep */
.radar-sweep {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 50%;
  height: 2rpx;
  transform-origin: left center;
  overflow: hidden;
}

.sweep-line {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, var(--color-accent-warm), transparent);
  transform: rotate(-90deg);
  transform-origin: left center;
  animation: sweepRotate 4s linear infinite;
}

@keyframes sweepRotate {
  from { transform: rotate(-90deg); }
  to { transform: rotate(270deg); }
}

/* Radar Center */
.radar-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 24rpx;
}

.center-dot {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 16rpx;
  height: 16rpx;
  background: var(--color-accent-warm);
  border-radius: 50%;
}

.center-pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 24rpx;
  background: var(--color-accent-warm);
  border-radius: 50%;
  opacity: 0.5;
  animation: centerPulse 2s ease-out infinite;
}

@keyframes centerPulse {
  0% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.5;
  }
  100% {
    transform: translate(-50%, -50%) scale(2);
    opacity: 0;
  }
}

/* User Points */
.user-point {
  position: absolute;
  top: 50%;
  left: 50%;
  transform-origin: center;
  z-index: 10;
  transition: all 0.3s ease;
}

.point-dot {
  width: 20rpx;
  height: 20rpx;
  background: var(--point-color);
  border-radius: 50%;
  box-shadow: 0 0 10rpx var(--point-color);
  transition: all 0.3s ease;
}

.user-point.pulse .point-dot {
  animation: pointPulse 0.5s ease-out;
}

@keyframes pointPulse {
  0% {
    transform: scale(1);
    box-shadow: 0 0 10rpx var(--point-color);
  }
  50% {
    transform: scale(1.5);
    box-shadow: 0 0 30rpx var(--point-color);
  }
  100% {
    transform: scale(1);
    box-shadow: 0 0 10rpx var(--point-color);
  }
}

/* Frequency Labels */
.radar-labels {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.freq-label {
  position: absolute;
  font-size: var(--font-size-micro);
  color: var(--color-text-muted);
}

.freq-label.top {
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
}

.freq-label.right {
  right: -10rpx;
  top: 50%;
  transform: translateY(-50%);
}

.freq-label.bottom {
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
}

.freq-label.left {
  left: -10rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* Resonance Info */
.resonance-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-text {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
}

.broadcast-btn {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-lg);
  background: rgba(224, 122, 95, 0.15);
  border: 1px solid var(--color-accent-warm);
  border-radius: var(--radius-full);
  transition: all 0.3s ease;
}

.broadcast-btn:active {
  transform: scale(0.98);
}

.broadcast-icon {
  width: 24rpx;
  height: 24rpx;
  background: var(--color-accent-warm);
  border-radius: 50%;
  position: relative;
}

.broadcast-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--color-accent-warm);
  border-radius: 50%;
  animation: broadcastPulse 1.5s ease-out infinite;
}

@keyframes broadcastPulse {
  0% {
    transform: translate(-50%, -50%) scale(0.8);
    opacity: 1;
  }
  100% {
    transform: translate(-50%, -50%) scale(1.5);
    opacity: 0;
  }
}

.broadcast-btn text {
  font-size: var(--font-size-caption);
  color: var(--color-accent-warm);
}

/* Users Section */
.users-section {
  margin-bottom: var(--spacing-xl);
}

.users-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.user-card {
  display: flex;
  align-items: center;
  padding: var(--spacing-md);
  border-radius: var(--radius-md);
  transition: all 0.3s ease;
}

.user-card:active {
  transform: scale(0.98);
  background: rgba(27, 38, 59, 0.8);
}

.user-avatar {
  position: relative;
  margin-right: var(--spacing-md);
}

.avatar-bg {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: var(--font-size-h3);
  color: white;
  font-weight: 500;
}

.online-indicator {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  background: #81B29A;
  border: 4rpx solid var(--color-bg-primary);
  border-radius: 50%;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  display: block;
}

.user-freq {
  font-size: var(--font-size-micro);
  color: var(--color-text-secondary);
  display: block;
  margin-top: var(--spacing-xs);
}

.resonance-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.resonance-icon {
  width: 24rpx;
  height: 24rpx;
  background: var(--color-text-secondary);
  border-radius: 50%;
  position: relative;
}

.resonance-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid transparent;
  border-radius: 50%;
}

/* Meteor Section */
.meteor-section {
  margin-bottom: var(--spacing-xl);
}

.meteor-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-md);
  padding: var(--spacing-lg);
  background: linear-gradient(135deg, rgba(224, 122, 95, 0.2), rgba(244, 132, 95, 0.2));
  border: 1px solid rgba(224, 122, 95, 0.3);
  border-radius: var(--radius-lg);
  position: relative;
}

.meteor-btn text {
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
}

.level-badge {
  position: absolute;
  top: var(--spacing-sm);
  right: var(--spacing-sm);
  padding: var(--spacing-xs) var(--spacing-sm);
  background: var(--color-accent-warm);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-micro);
  color: white;
}

.meteor-icon {
  position: relative;
  width: 40rpx;
  height: 40rpx;
}

.meteor-head {
  width: 16rpx;
  height: 16rpx;
  background: var(--color-accent-warm);
  border-radius: 50%;
  position: absolute;
  top: 12rpx;
  left: 12rpx;
}

.meteor-trail {
  position: absolute;
  top: 50%;
  right: 50%;
  transform: translate(50%, -50%) rotate(-45deg);
  width: 50rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--color-accent-warm));
  border-radius: 2rpx;
}
