/* components/emotion-display/index.wxss */

.emotion-display {
  width: 100%;
}

/* Intensity Section */
.intensity-section {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-lg);
}

.intensity-label {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  white-space: nowrap;
}

.intensity-bar {
  flex: 1;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.intensity-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-accent-lavender), var(--color-accent-warm));
  border-radius: var(--radius-full);
  transition: width 0.5s ease-out;
}

.intensity-value {
  font-size: var(--font-size-caption);
  color: var(--color-accent-warm);
  font-weight: 500;
  min-width: 60rpx;
  text-align: right;
}

/* Emotions Container */
.emotions-container {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-lg);
}

.emotion-item {
  opacity: 0;
  animation: slideUp 0.4s ease-out forwards;
}

.emotion-card {
  position: relative;
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  border: 1px solid rgba(255, 255, 255, 0.05);
  overflow: hidden;
  min-width: 160rpx;
}

.emotion-glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 60rpx;
  background: var(--emotion-color);
  opacity: 0.15;
  filter: blur(20rpx);
}

.emotion-content {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.emotion-label {
  font-size: var(--font-size-caption);
  color: var(--emotion-color);
  font-weight: 500;
}

.emotion-bar {
  width: 100%;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.emotion-bar-fill {
  height: 100%;
  background: var(--emotion-color);
  border-radius: var(--radius-full);
  transition: width 0.5s ease-out;
}

.emotion-percent {
  font-size: var(--font-size-micro);
  color: var(--color-text-secondary);
}

/* Dominant Section */
.dominant-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) var(--spacing-lg);
  background: rgba(255, 255, 255, 0.03);
  border-radius: var(--radius-md);
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.dominant-label {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
}

.dominant-display {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.dominant-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

.dominant-text {
  font-size: var(--font-size-body);
  color: var(--color-text-primary);
  font-weight: 500;
}
