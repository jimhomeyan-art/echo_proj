/* components/music-player/index.wxss */

.music-player {
  padding: var(--spacing-lg);
  background: var(--color-bg-secondary);
  border-radius: var(--radius-lg);
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.music-player.compact {
  padding: var(--spacing-md);
}

/* Header with Cover */
.player-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

.cover-wrapper {
  flex-shrink: 0;
}

.cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.music-player.compact .cover {
  width: 80rpx;
  height: 80rpx;
}

.cover-inner {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-glow {
  width: 60%;
  height: 60%;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  filter: blur(10rpx);
}

.cover.playing {
  animation: rotateCover 10s linear infinite;
}

@keyframes rotateCover {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* Info */
.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.title {
  font-size: var(--font-size-h3);
  font-weight: 500;
  color: var(--color-text-primary);
}

.artist {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
}

/* Waveform */
.waveform-container {
  margin-bottom: var(--spacing-lg);
}

.waveform {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 6rpx;
  height: 60rpx;
}

.wave-bar {
  width: 4rpx;
  background: linear-gradient(to top, var(--color-accent-warm), var(--color-accent-lavender));
  border-radius: var(--radius-full);
  transition: height 0.15s ease-out;
}

.wave-bar.active {
  animation: wavePulse 0.5s ease-in-out infinite alternate;
}

@keyframes wavePulse {
  from { opacity: 0.6; }
  to { opacity: 1; }
}

/* Progress */
.progress-section {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-lg);
}

.time {
  font-size: var(--font-size-micro);
  color: var(--color-text-secondary);
  width: 80rpx;
  text-align: center;
}

.time.current {
  color: var(--color-accent-warm);
}

.progress-wrapper {
  flex: 1;
}

.progress-track {
  position: relative;
  height: 48rpx;
  display: flex;
  align-items: center;
}

.progress-bg {
  position: absolute;
  width: 100%;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-full);
}

.progress-fill {
  position: absolute;
  height: 4rpx;
  background: linear-gradient(90deg, var(--color-accent-warm), var(--color-accent-coral));
  border-radius: var(--radius-full);
  transition: width 0.1s linear;
}

.progress-thumb {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  background: white;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  transform: translateX(-50%);
  transition: left 0.1s linear;
}

/* Controls */
.controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: var(--spacing-xl);
}

.control-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.control-btn.primary {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--color-accent-warm), var(--color-accent-coral));
  box-shadow: 0 4rpx 20rpx rgba(224, 122, 95, 0.4);
}

.control-btn.primary:active {
  transform: scale(0.95);
}

.control-btn.primary.playing {
  animation: glowPulse 2s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% {
    box-shadow: 0 4rpx 20rpx rgba(224, 122, 95, 0.4);
  }
  50% {
    box-shadow: 0 4rpx 30rpx rgba(224, 122, 95, 0.6);
  }
}

.control-btn.secondary {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.control-btn.secondary:active {
  background: rgba(255, 255, 255, 0.12);
}

/* Icons */
.icon-play,
.icon-pause {
  width: 0;
  height: 0;
  border-style: solid;
  margin-left: 4rpx;
}

.icon-play.play {
  border-width: 16rpx 0 16rpx 26rpx;
  border-color: transparent transparent transparent white;
}

.icon-play.pause {
  width: 24rpx;
  height: 24rpx;
  background: white;
  border-radius: 4rpx;
  margin: 0;
}

.icon-stop {
  width: 20rpx;
  height: 20rpx;
  background: var(--color-text-secondary);
  border-radius: 4rpx;
}

.icon-share {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid var(--color-text-secondary);
  border-radius: 50%;
  position: relative;
}

.icon-share::after {
  content: '';
  position: absolute;
  right: -4rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 6rpx 0 6rpx 8rpx;
  border-color: transparent transparent transparent var(--color-text-secondary);
}
